{
  "name": "@vk0/agent-claim-mcp",
  "version": "1.0.2",
  "description": "Local-first MCP server for parallel AI coding agents to claim file ownership before edits, preventing stomping on each other in the same worktree.",
  "mcpName": "io.github.vk0dev/agent-claim-mcp",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "server.json",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "agent-claim-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "smoke": "npm run build && node scripts/dogfood_smoke.mjs",
    "smoke:release": "npm run build && node scripts/release_smoke_gate.mjs",
    "preflight:registry": "node scripts/registry_preflight_packet.mjs",
    "dogfood:overlap": "npm run build && node scripts/demo-claim-conflict.mjs",
    "dogfood:expiry": "npm run build && node scripts/demo-expiry-prune.mjs",
    "dogfood:release-owner": "npm run build && node scripts/demo-owner-release.mjs",
    "version-sync": "node scripts/version-sync.mjs",
    "release-check": "node scripts/release-check.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "anthropic",
    "ai-agent",
    "agent-coordination",
    "parallel-agents",
    "file-lock",
    "worktree",
    "claims",
    "developer-tools",
    "local-first",
    "json-ledger",
    "cursor",
    "codex"
  ],
  "author": "vk0.dev",
  "license": "MIT",
  "homepage": "https://vk0dev.github.io/agent-claim-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/vk0dev/agent-claim-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vk0dev/agent-claim-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  }
}
